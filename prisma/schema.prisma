generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Job {
  id              String             @id @default(uuid())
  organization    String
  postName        String
  qualification   String
  vacancy         String
  lastDate        String
  title           String
  postDescription String             @db.Text
  salary          String?
  ageLimit        String?
  startDate       String?
  examDate        String?
  officialWebsite String?
  mode            String?
  paymentMode     String?
  howToApply      String?            @db.Text
  createdAt       DateTime           @default(now())
  image           String?            @db.Text
  categories      JobCategory[]
  notifications   JobNotification[]
  links           JobLink[]
  selectionProcess SelectionProcess[]
  ageRelaxations   AgeRelaxation[]
  applicationFees  ApplicationFee[]
  comments         Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  jobId     String?
  content   String   @db.Text
  name      String
  email     String
  website   String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
}

model Category {
  id    Int           @id @default(autoincrement())
  name  String        @unique
  jobs  JobCategory[]
}

model JobCategory {
  jobId      String
  categoryId Int
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([jobId, categoryId])
}

model JobNotification {
  id    Int    @id @default(autoincrement())
  jobId String
  label String
  value String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobLink {
  id    Int    @id @default(autoincrement())
  jobId String
  label String
  url   String @db.Text
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model SelectionProcess {
  id    Int    @id @default(autoincrement())
  jobId String
  step  String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model AgeRelaxation {
  id    Int    @id @default(autoincrement())
  jobId String
  rule  String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ApplicationFee {
  id    Int    @id @default(autoincrement())
  jobId String
  fee   String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// --- Dynamic Site Assets Models ---

model AssetCategory {
  id       Int     @id @default(autoincrement())
  name     String
  icon     String? @db.Text
  link     String
  useEmoji Boolean @default(false)
}

model EducationVacancy {
  id   Int    @id @default(autoincrement())
  name String
  link String
}

model PostWiseRecruitment {
  id   Int    @id @default(autoincrement())
  name String
  link String
}

model FAQ {
  id       Int    @id @default(autoincrement())
  question String @db.Text
  answer   String @db.Text
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

